<odoo>
    <record id="view_cancel_wizard_form" model="ir.ui.view">
        <field name="name">appointment.cancel.wizard.form</field>
        <field name="model">appointment.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancel Appointment" create="false" edit="false">
                <group>
                    <field name="reason" required="1"/>
                    <field name="appointment_id" readonly="1"/>
                </group>

                <footer>
                    <button name="action_confirm_cancel"
                            type="object"
                            string="Confirm Cancel"
                            class="btn-danger"/>

                    <button string="Close"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>