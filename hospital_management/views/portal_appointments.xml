<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =====================================
         Add Appointments Card in Portal Home
    ====================================== -->

    <template id="portal_my_home_appointments"
              inherit_id="portal.portal_my_home"
              name="Add Appointments Card">

        <xpath expr="//div[@id='portal_common_category']" position="inside">

            <t t-call="portal.portal_docs_entry">

                <t t-set="icon"
                   t-value="'/portal/static/src/img/portal-addresses.svg'"/>

                <t t-set="title">
                    Appointments
                </t>

                <t t-set="text">
                    View your hospital appointments
                </t>

                <t t-set="url"
                   t-value="'/my/appointments'"/>

                <t t-set="config_card" t-value="True"/>

            </t>

        </xpath>

    </template>

    <template id="portal_breadcrumbs_appointments"
            inherit_id="portal.portal_breadcrumbs"
            name="Appointments Breadcrumb">

        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">

            <!-- LIST PAGE -->
            <li t-if="page_name == 'appointments'"
                class="breadcrumb-item active">
                Appointments
            </li>

            <!-- DETAIL PAGE -->
            <li t-if="page_name == 'appointment'"
                class="breadcrumb-item">
                <a href="/my/appointments">Appointments</a>
            </li>

            <li t-if="page_name == 'appointment'"
                class="breadcrumb-item active">
                <t t-esc="appointment.name"/>
            </li>

        </xpath>

    </template>

    <!-- =====================================
         Portal Appointment List Page
    ====================================== -->

    <template id="portal_my_appointments_page"
              name="My Appointments">

        <t t-call="portal.portal_layout">
            <t t-set="page_name" t-value="'appointments'"/>

            <div class="container mt-4">

                <table class="table table-hover">

                    <thead>
                        <tr>
                            <th>Appointment No</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Specialization</th>
                            <th>Date</th>
                            <th>Fees</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>

                        <t t-if="appointments">

                            <t t-foreach="appointments" t-as="app">

                                <tr>

                                    <td>
                                        <a t-att-href="'/my/appointment/%s' % app.id">
                                        <t t-esc="app.name"/>
                                        </a>
                                    </td>

                                    <td><t t-esc="app.patient_id.name"/></td>
                                    <td><t t-esc="app.doctor_id.name"/></td>
                                    <td><t t-esc="app.specialization_id.name"/></td>

                                    <td>
                                        <span t-field="app.start_date"/>
                                    </td>

                                    <td>
                                        <span t-field="app.fees"
                                            t-options='{"widget": "monetary", "display_currency": app.currency_id}'/>
                                    </td>

                                    <td>

                                        <span class="badge bg-success"
                                              t-if="app.state == 'done'">Done</span>

                                        <span class="badge bg-info"
                                              t-if="app.state == 'confirmed'">Confirmed</span>

                                        <span class="badge bg-warning"
                                              t-if="app.state == 'requested'">Requested</span>

                                        <span class="badge bg-danger"
                                              t-if="app.state == 'cancel'">Cancelled</span>

                                        <span class="badge bg-secondary"
                                              t-if="app.state == 'draft'">Draft</span>

                                    </td>

                                </tr>

                            </t>

                        </t>

                        <t t-if="not appointments">

                            <tr>
                                <td colspan="7" class="text-center text-muted">
                                    No appointments found
                                </td>
                            </tr>

                        </t>

                    </tbody>

                </table>
                <t t-if="pager">
                    <div class="mt-3 d-flex justify-content-center">
                        <t t-call="portal.pager"/>
                    </div>
                </t>

            </div>

        </t>

    </template>



<template id="portal_appointment_page"
          name="Appointment Portal"
          inherit_id="portal.portal_sidebar"
          primary="True">

    <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">

        <div class="row">

            <!-- =======================
                 SIDEBAR (LEFT)
            ======================== -->
<t t-call="portal.portal_record_sidebar">

    <!-- Sidebar width -->
    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>

    <!-- ================= TITLE ================= -->
    <t t-set="title">
        <h2 class="mb-0 text-break">
            <span t-field="appointment.fees"
                t-options='{"widget": "monetary", "display_currency": appointment.currency_id}'/>
        </h2>
    </t>

    <!-- ================= ENTRIES ================= -->
    <t t-set="entries">
        <!-- ================= BUTTONS ================= -->
        <div class="d-flex flex-column gap-4 mt-3">

            <div class="d-flex flex-column gap-2">

                <!-- Download -->
                <a class="btn btn-light"
                   t-att-href="'/my/appointment/%s?report_type=pdf' % appointment.id"
                   target="_blank">
                    <i class="fa fa-print me-1"/> View Details
                </a>

            </div>

            <!-- ================= NAV LINKS ================= -->
            <div class="navspy flex-grow-1 ps-0">

                <ul class="nav flex-column bs-sidenav">

                    <li class="nav-item">
                        <a class="nav-link"
                           href="#appointment_top">
                            Appointment
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="#medical_info">
                            Medical Info
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="#appointment_communication">
                            Communication History
                        </a>
                    </li>

                </ul>

            </div>

            <!-- Company -->
            <div t-if="appointment.company_id">

                <h6><small class="text-muted">Your Connect</small></h6>

                <t t-call="portal.portal_my_contact">

                    <t t-set="_contactAvatar"
                    t-value="appointment.company_id.logo and image_data_uri(appointment.company_id.logo) or '/web/static/img/user_placeholder.png'"/>

                    <t t-set="_contactName"
                    t-value="appointment.company_id.name or 'Company'"/>

                    <t t-set="_contactLink"
                    t-value="True"/>

                </t>

            </div>
        </div>

    </t>

</t>

            <!-- =======================
                 RIGHT CONTENT
            ======================== -->
            <div class="col-12 col-lg-8 col-xxl-9 o_portal_content">

                <!-- HEADER -->
                <div class="d-flex justify-content-between align-items-center mb-3">

                    <!-- TOP TARGET -->
                    <h2 id="appointment_top">
                        Appointment -
                        <em t-esc="appointment.name"/>
                    </h2>

                    <!-- STATUS -->
                    <div class="my-2 text-center">
                        <span class="badge bg-success" t-if="appointment.state == 'done'">Done</span>
                        <span class="badge bg-info" t-if="appointment.state == 'confirmed'">Confirmed</span>
                        <span class="badge bg-warning" t-if="appointment.state == 'requested'">Requested</span>
                        <span class="badge bg-danger" t-if="appointment.state == 'cancel'">Cancelled</span>
                        <span class="badge bg-secondary" t-if="appointment.state == 'draft'">Draft</span>
                    </div>

                </div>

                <hr/>

                <!-- DETAILS -->
                <div class="row">

                    <div class="col-md-6">
                        <h5>Appointment Info</h5>
                        <hr/>

                        <p><strong>Patient:</strong>
                            <t t-esc="appointment.patient_id.name"/>
                        </p>

                        <p><strong>Doctor:</strong>
                            <t t-esc="appointment.doctor_id.name"/>
                        </p>

                        <p><strong>Specialization:</strong>
                            <t t-esc="appointment.specialization_id.name"/>
                        </p>
                    </div>

                    <div class="col-md-6">
                        <h5>Schedule</h5>
                        <hr/>

                        <p><strong>Start:</strong>
                            <span t-field="appointment.start_date"/>
                        </p>

                        <p><strong>End:</strong>
                            <span t-field="appointment.end_date"/>
                        </p>
                    </div>

                </div>

                <hr/>

                <!-- MEDICAL INFO -->
                <h3 id="medical_info">Medical Information</h3>

                <p>
                    <strong>Symptoms:</strong><br/>
                    <t t-esc="appointment.symptoms"/>
                </p>

                <p>
                    <strong>Doctor Notes:</strong><br/>
                    <t t-esc="appointment.notes"/>
                </p>

                <!-- ADD THIS -->
                <t t-if="appointment.state == 'cancel' and appointment.cancel_reason">
                    <hr/>
                    <h5>Cancellation Reason</h5>
                    <p class="text-danger">
                        <t t-esc="appointment.cancel_reason"/>
                    </p>
                </t>

                <hr/>

                <!-- CHATTER -->
                <h3 id="appointment_communication">Communication history</h3>

                <div>
                    <t t-set="object" t-value="appointment"/>
                    <t t-call="portal.message_thread"/>
                </div>

            </div>

        </div>

    </xpath>

</template>



</odoo>