<odoo>
<template id="s_specialization_list" name="Specialization List">
    <section class="s_specialization_list"
         data-snippet="hospital_management.specialization_list"
         >

        <div class="container">
            <div class="row o_specialization_container">

                <t t-if="request.env.context.get('editable')">
                    <t t-call="hospital_management.s_specialization_list_preview_data"/>
                </t>

            </div>
        </div>

    </section>
</template>

<template id="specialization_card_template">

    <t t-foreach="specializations" t-as="spec">
        <div class="col-3">
            <div class="card p-3 text-center">
                <h5><t t-out="spec.name"/></h5>
            </div>
        </div>
    </t>

</template>

</odoo>