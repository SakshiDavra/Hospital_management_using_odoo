<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="my_image_text_snippet" name="Image Text Demo">
        <section class="o_snippet s_image_text py-5 bg-light">
            <div class="container">
                <div class="row align-items-center">

                    <div class="col-lg-6">
                        <h2>Welcome to Our Hospital</h2>
                        <p>This is my static snippet demo.</p>
                    </div>

                    <div class="col-lg-6">
                        <img src="/hospital_management/static/src/img/sample.png" alt="Sample Image"
                         class="img-fluid rounded"/>
                    </div>

                </div>
            </div>
        </section>
    </template>

</odoo>