<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Action -->
    <record id="action_hospital_role" model="ir.actions.act_window">
        <field name="name">Hospital Roles</field>
        <field name="res_model">hospital.role</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- List View -->
    <record id="view_hospital_role_list" model="ir.ui.view">
        <field name="name">hospital.role.list</field>
        <field name="model">hospital.role</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hospital_role_form" model="ir.ui.view">
        <field name="name">hospital.role.form</field>
        <field name="model">hospital.role</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>