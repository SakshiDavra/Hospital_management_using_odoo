<t t-name="hospital_dashboard_template">

    <Layout display="{'controlPanel': {}}">

        <!-- LOADER -->
        <t t-if="state.loading">
            <div class="text-center mt-5">
                <i class="fa fa-spinner fa-spin fa-2x"></i>
                <p>Loading dashboard...</p>
            </div>
        </t>

        <!-- DASHBOARD -->
        <t t-else="">

            <!-- CARDS -->
            <div class="container mt-4">
                <div class="row mt-4">

                    <t t-foreach="state.cards" t-as="card" t-key="card.key">
                        <div class="col-lg-4 col-md-6 mb-3">
                            <CounterCard
                                title="card.title"
                                value="state.data[card.key] || 0"
                                bg="card.bg"
                                icon="card.icon"
                                onClick="() => this.openList(card.action)"
                            />
                        </div>
                    </t>

                </div>
            </div>

            <!-- CHARTS -->
            <div class="container mt-4">
                <div class="row">

                    <!-- PIE -->
                    <div class="col-lg-6 col-md-12 mb-3">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-3">
                                <h5>Appointment Status</h5>

                                <t t-if="state.state_data and state.state_data.length">
                                    <PieChart data="state.state_data"/>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- BAR -->
                    <div class="col-lg-6 col-md-12 mb-3">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-3">

                                <div class="d-flex justify-content-between mb-3">
                                    <h5>Appointments Analytics</h5>

                                    <select class="form-select w-auto"
                                            t-model="state.filter"
                                            t-on-change="onFilterChange">
                                        <option value="week">This Week</option>
                                        <option value="month">This Month</option>
                                        <option value="year">This Year</option>
                                    </select>
                                </div>

                                <t t-if="state.chart_data and state.chart_data.labels">
                                    <BarChart data="state.chart_data"/>
                                </t>

                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- CANVAS + TOP DOCTORS (SIDE BY SIDE) -->
            <div class="container mt-4">
                <div class="row">

                    <!-- LEFT → CANVAS -->
                    <div class="col-lg-6 col-md-12 mb-3">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-3">
                                <h5>Draw Shapes</h5>
                                <ShapeCanvas/>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT → TABLE -->
                    <div class="col-lg-6 col-md-12 mb-3">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-3">

                                <h5>Top 5 Doctors</h5>

                                <table class="table table-hover">

                                    <thead class="table-light">
                                        <tr>
                                            <th>Doctor Name</th>
                                            <th>Total Appointments</th>
                                        </tr>
                                    </thead>

                                    <tbody>

                                        <t t-if="state.top_doctors and state.top_doctors.length">

                                            <t t-foreach="state.top_doctors"
                                               t-as="doc"
                                               t-key="doc.doctor">

                                                <tr>
                                                    <td><t t-esc="doc.doctor"/></td>

                                                    <td>
                                                        <span style="
                                                            display:inline-block;
                                                            padding:1px 8px;
                                                            border:3px solid #ccc;
                                                            border-radius:50px;
                                                            text-align:center;">
                                                            <t t-esc="doc.count"/>
                                                        </span>
                                                    </td>
                                                </tr>

                                            </t>

                                        </t>

                                        <t t-else="">
                                            <tr>
                                                <td colspan="2" class="text-center text-muted">
                                                    No data found
                                                </td>
                                            </tr>
                                        </t>

                                    </tbody>

                                </table>

                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- TODO SECTION -->
            <div class="container mt-4">
                <div class="row">

                    <!-- LEFT → TODO -->
                    <div class="col-lg-12 col-md-12 mb-3">
                        <TodoList todos="state.todos"/>
                    </div>


                </div>
            </div>

        </t>

    </Layout>

</t>