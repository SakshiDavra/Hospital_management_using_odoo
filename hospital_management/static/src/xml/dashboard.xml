<t t-name="hospital_dashboard_template">

    <Layout display="{'controlPanel': {}}">

        <t t-if="state.isLoading">
            <div class="d-flex justify-content-center align-items-center"
                style="height: 80vh;">
                
                <div class="text-center">
                    <i class="fa fa-spinner fa-spin fa-3x mb-3"></i>
                    <h5>Loading Dashboard...</h5>
                </div>

            </div>
        </t>
        <t t-else="">
        <!-- DASHBOARD -->
    
            <!-- CARDS -->
            <div class="container mt-4">
                <div class="row mt-4">

                    <t t-foreach="state.cards" t-as="card" t-key="card.key">
                        <div class="col-lg-4 col-md-6 mb-3">
                            <CounterCard
                                title="card.title"
                                value="state.cardData[card.key] || 0"
                                bg="card.bg"
                                icon="card.icon"
                                onClick="() => this.openList(card.action)"
                            />
                        </div>
                    </t>

                </div>
            </div>
            <!-- PIE CHART -->
            <div class="container mt-4">
                <div class="row">

                    <!-- LEFT SIDE (CHART) -->
                    <div class="col-lg-6 col-md-6">
                        <div class="card shadow p-3" style="height: 350px;">
                            <h4 class="text-center">Appointment Status</h4>

                            <PieChart 
                                t-key="'pie_chart_static'"
                                t-props="{
                                    data: state.pieData,
                                    showCenterTotal: true,
                                    centerLabel: 'Total Appointments',
                                    total: Object.values(state.pieData || {}).reduce((a,b)=>a+b,0),
                                    onClick: (status) => this.openStatusList(status)
                                }"
                            />
                        </div>
                    </div>

                    <!-- RIGHT SIDE -->
                    <div class="col-lg-6 col-md-6">
                        <div class="card shadow p-3" style="height: 350px;">

                            <!-- HEADER WITH DROPDOWN -->
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h4 class="mb-0">Appointments</h4>

                                <select class="form-select w-auto"
                                    t-on-change="(ev) => this.onFilterChange(ev)">
                                    <option value="week" t-att-selected="state.filter === 'week'">This Week</option>
                                    <option value="month" t-att-selected="state.filter === 'month'">This Month</option>
                                    <option value="year" t-att-selected="state.filter === 'year'">This Year</option>
                                </select>
                            </div>

                            <!-- CHART -->
                            <t t-if="state.chartData and Object.keys(state.chartData).length">
                                <BarChart 
                                    t-key="state.filter"
                                    t-props="{
                                        data: state.chartData || {},
                                        label: 'Appointments',
                                        onClick: (day, status) => this.openWeekDay(day, status)
                                    }"
                                />
                            </t>

                            <t t-else="">
                                <div class="text-center mt-5">
                                    <i class="fa fa-spinner fa-spin"></i>
                                </div>
                            </t>

                        </div>
                    </div>

                </div>
            </div>
            <div class="container mt-4">
                <div class="row">

                    <!-- LEFT SIDE (Canvas) -->
                    <div class="col-lg-6 col-md-6">
                        <div class="card shadow p-3 h-100">
                            <h4>Drawing Canvas</h4>

                            <ShapeCanvas />
                        </div>
                    </div>

                    <!-- RIGHT SIDE (Future use) -->
                    <div class="col-lg-6 col-md-6">
                        <div class="card shadow p-3 h-100">
                            
                            <h4 class="mb-3">Todo List</h4>

                            <TodoList/>

                        </div>
                    </div>
                    

                </div>
            </div>

            <!-- NEW ROW -->
            <div class="container mt-4">
                <div class="row g-3">

                    <!-- LEFT: TOP DOCTORS -->
                    <div class="col-lg-6 col-md-6">
                        <div class="card shadow p-3 h-100">

                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h3 class="mb-0 fw-bold">Top 5 Doctors</h3>
                                <!-- <span class="badge bg-primary">Top</span> -->
                            </div>

                            <TopDoctors/>

                        </div>
                    </div>

                    <!-- RIGHT: FUTURE -->
                    <div class="col-lg-6 col-md-6">
                        <div class="card shadow p-3 h-100 d-flex justify-content-center align-items-center">

                            <h5 class="text-muted">Future Feature Area 🚀</h5>

                        </div>
                    </div>

                </div>
            </div>
                    
       </t>

    </Layout>

</t>