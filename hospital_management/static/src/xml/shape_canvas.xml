<t t-name="shape_canvas_template">
    <div>

        <!-- TOOLBAR -->
        <div class="mb-2 d-flex gap-2">
            <button class="btn btn-primary" t-on-click="() => this.setShape('square')">Square</button>
            <button class="btn btn-success" t-on-click="() => this.setShape('circle')">Circle</button>
            <button class="btn btn-warning" t-on-click="() => this.setShape('triangle')">Triangle</button>
            <button class="btn btn-danger" t-on-click="() => this.setShape('pentagon')">Pentagon</button>

            <input type="color" t-on-change="setColor"/>
            <button class="btn btn-secondary" t-on-click="clearCanvas">Clear</button>
        </div>

        <!-- SVG DRAW AREA -->
        <svg 
            t-on-click="onCanvasClick"
            style="width:100%; height:250px; border:1px solid #ccc; background:#f9f9f9;"
        >
            <t t-foreach="state.shapes" t-as="shape" t-key="shape_index">

                <!-- SQUARE -->
                <rect t-if="shape.type === 'square'"
                    t-att-x="shape.x - 40"
                    t-att-y="shape.y - 40"
                    width="80"
                    height="80"
                    t-att-fill="shape.filled ? shape.color : 'transparent'"
                    stroke="black"
                />

                <!-- CIRCLE -->
                <circle t-if="shape.type === 'circle'"
                    t-att-cx="shape.x"
                    t-att-cy="shape.y"
                    r="40"
                    t-att-fill="shape.filled ? shape.color : 'transparent'"
                    stroke="black"
                />

                <!-- TRIANGLE -->
                <polygon t-if="shape.type === 'triangle'"
                    t-att-points="`${shape.x},${shape.y-40} ${shape.x-40},${shape.y+40} ${shape.x+40},${shape.y+40}`"
                    t-att-fill="shape.filled ? shape.color : 'transparent'"
                    stroke="black"
                />

                <!-- PENTAGON -->
                <polygon t-if="shape.type === 'pentagon'"
                    t-att-points="
                        `${shape.x},${shape.y-40}
                        ${shape.x-38},${shape.y-12}
                        ${shape.x-24},${shape.y+40}
                        ${shape.x+24},${shape.y+40}
                        ${shape.x+38},${shape.y-12}`"
                    t-att-fill="shape.filled ? shape.color : 'transparent'"
                    stroke="black"
                />

            </t>

        </svg>

    </div>
</t>