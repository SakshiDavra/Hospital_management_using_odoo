<t t-name="counter_card_template">
    <div class="card custom-card shadow-sm border-0 p-3"
         t-att-class="props.bg"
         t-on-click="props.onClick">

        <div class="d-flex justify-content-between align-items-center">

            <!-- LEFT TEXT -->
            <div>
                <div class="text-muted small fw-semibold">
                    <t t-esc="props.title"/>
                </div>

                <div class="fs-3 fw-bold mt-1">
                    <t t-esc="props.value"/>
                </div>
            </div>

            <!-- RIGHT ICON -->
            <div class="icon-box">
                <i t-att-class="props.icon"></i>
            </div>

        </div>

    </div>
</t>