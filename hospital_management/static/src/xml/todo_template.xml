<t t-name="hospital_todo_list_template">

    <div class="card shadow-sm border-0 h-100">
        <div class="card-body p-3">

            <!-- TITLE + FILTER -->
            <div class="d-flex justify-content-between mb-2">

                <h5>Todo List</h5>

                <select class="form-select w-auto"
                        t-model="state.filter">

                    <option value="all">All</option>
                    <option value="done">Done</option>
                    <option value="pending">Pending</option>

                </select>

            </div>

            <!-- ADD INPUT -->
            <div class="d-flex align-items-center mb-2">

                <input type="text"
                       class="form-control me-2 todo-input"
                       placeholder="Add new task..."/>

                <button class="btn btn-primary"
                        t-on-click="addTodo">
                    Add
                </button>

            </div>

            <!-- COUNTER -->
            <div class="mb-3">

                <span class="me-3">
                    Total: <t t-esc="total"/>
                </span>

                <span class="me-3 text-success">
                    Done: <t t-esc="doneCount"/>
                </span>

                <span class="text-warning">
                    Pending: <t t-esc="pendingCount"/>
                </span>

            </div>

            <!-- TODO LIST -->
            <ul class="list-group">

                <t t-if="filteredTodos and filteredTodos.length">

                    <!-- 🔥 IMPORTANT CHANGE -->
                    <t t-foreach="filteredTodos" t-as="todo" t-key="todo.id">

                        <li class="list-group-item d-flex justify-content-between align-items-center">

                            <!-- LEFT -->
                            <div class="d-flex align-items-center">

                                <input type="checkbox"
                                       class="form-check-input me-2"
                                       t-att-checked="todo.is_done"
                                       t-on-change="() => toggleTodo(todo)"/>

                                <span t-att-class="todo.is_done ? 'text-decoration-line-through text-muted' : ''">
                                    <t t-esc="todo.name"/>
                                </span>

                            </div>

                            <!-- RIGHT -->
                            <div>

                                <span t-if="todo.is_done"
                                      class="badge bg-success me-2">
                                    Done
                                </span>

                                <button class="btn btn-sm btn-danger"
                                        t-on-click="() => this.deleteTodo(todo)">
                                    ✕
                                </button>

                            </div>

                        </li>

                    </t>

                </t>

                <t t-else="">
                    <li class="list-group-item text-muted text-center">
                        No Todos Found
                    </li>
                </t>

            </ul>

        </div>
    </div>

</t>