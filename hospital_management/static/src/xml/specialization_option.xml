        <BuilderSelect action="'setRecordLimit'" preview="false">

            <!-- Dynamic loop -->
            <t t-foreach="Array.from({ length: this.count }, (_, i) => i + 1)" t-as="num" t-key="num">

                <BuilderSelectItem
                    actionValue="num"
                    t-out="num"
                />

            </t>

        </BuilderSelect>

    </BuilderRow>

    <!-- NEW STYLE OPTION -->
    <BuilderRow label.translate="Template Style">

        <BuilderSelect action="'setTemplateStyle'" preview="false">
            <BuilderSelectItem actionValue="'Style-Default'">Style-Default</BuilderSelectItem>
            <BuilderSelectItem actionValue="'Style-Grid'">Style-Grid</BuilderSelectItem>
            <BuilderSelectItem actionValue="'Style-Listview'">Style-Listview</BuilderSelectItem>
        </BuilderSelect>

    </BuilderRow>

</t>

