<odoo>
    <data>


        <record id="rule_patient_own_appointments" model="ir.rule">
            <field name="name">Patient: See Only Own Appointments</field>
            <field name="model_id" ref="model_hospital_appointment"/>

            <field name="groups" eval="[(4, ref('hospital_management.group_hospital_patient'))]"/>

            <field name="domain_force">
                [('patient_id.user_id','=',user.id)]
            </field>
        </record>

        <record id="rule_doctor_own_appointments" model="ir.rule">
            <field name="name">Doctor Own Appointments</field>
            <field name="model_id" ref="model_hospital_appointment"/>
            <field name="groups" eval="[(4, ref('hospital_management.group_hospital_doctor'))]"/>
            <field name="domain_force">
                [('doctor_id.user_id','=',user.id)]
            </field>
        </record>

    </data>
</odoo>