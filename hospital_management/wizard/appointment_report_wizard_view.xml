<odoo>

    <!-- Appointment Report Wizard -->

    <record id="view_appointment_report_wizard" model="ir.ui.view">
        <field name="name">appointment.report.wizard.form</field>
        <field name="model">appointment.report.wizard</field>

        <field name="arch" type="xml">

            <form string="Appointment Report">

                <sheet>

                    <group>
                        <group string="Basic Filters">
                        <!-- Basic Filters -->
                            <field name="doctor_ids"
                                widget="many2many_tags"
                                domain="[('role_ids.name','=','Doctor')]"
                                groups="hospital_management.group_hospital_admin,base.group_system"/>

                            <field name="patient_ids"
                                widget="many2many_tags"
                                domain="[('role_ids.name','=','Patient')]"/>
                            <field name="status_ids" widget="many2many_checkboxes"/>

                        </group>

                        <!-- Date Filters -->
                        <group string="Date Filters">

                            <field name="date_from"/>
                            <field name="date_to"/>


                        </group>

                    </group>

                </sheet>

                <footer>

                    <button name="action_print_report"
                            type="object"
                            string="Generate Report"
                            class="btn-primary"/>

                    <button name="action_export_excel"
                            type="object"
                            string="Generate Excel Report"
                            class="btn-warning"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>

                </footer>

            </form>

        </field>

    </record>


    <!-- Wizard Action -->

    <record id="action_appointment_report_wizard" model="ir.actions.act_window">
        <field name="name">Appointment Report</field>
        <field name="res_model">appointment.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>