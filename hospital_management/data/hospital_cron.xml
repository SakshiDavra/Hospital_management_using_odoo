<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="ir_cron_appointment_reminder" model="ir.cron">

            <field name="name">Hospital Appointment Reminder</field>

            <field name="model_id" ref="hospital_management.model_hospital_appointment"/>

            <field name="state">code</field>
            <field name="code">model.send_appointment_reminders()</field>

            <field name="interval_number">1</field>
            <field name="interval_type">days</field>

            <field name="user_id" ref="base.user_root"/>

            <field name="active" eval="True"/>

        </record>

    </data>

</odoo>