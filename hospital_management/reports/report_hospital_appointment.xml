<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- REPORT ACTION -->
    <record id="action_report_hospital_appointment" model="ir.actions.report">
        <field name="name">Appointment Report</field>
        <field name="model">hospital.appointment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hospital_management.report_hospital_appointment</field>
        <field name="report_file">hospital_management.report_hospital_appointment</field>
        <field name="print_report_name">'Appointment - %s' % (object.name)</field>
    </record>

    <!-- REPORT TEMPLATE -->
    <template id="report_hospital_appointment">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">

                <t t-call="web.external_layout">

                    <div class="page">

                    <div style="width:100%; margin-bottom:20px; overflow:hidden;">

                        <!-- LEFT -->
                        <div style="float:left; width:75%;">
                            <h2 style="color:#2a7f62; margin:0;">
                                Appointment - <t t-esc="doc.name"/>
                            </h2>
                        </div>

                        <!-- RIGHT BADGE -->
                        <div style="float:right; width:25%; text-align:right; margin-top:5px;">
                            
                            <t t-set="color" t-value="
                                'background-color:#5cb85c;' if doc.state == 'confirmed'
                                else 'background-color:#f0ad4e;' if doc.state == 'draft'
                                else 'background-color:#d9534f;' if doc.state == 'cancel'
                                else 'background-color:#777;'
                            "/>

                            <span t-att-style="color + ' color:white; padding:6px 14px; border-radius:14px; font-size:12px; text-transform:capitalize;'">
                                <t t-esc="doc.state"/>
                            </span>

                        </div>

                    </div>

                        <hr/>

                        <!-- MAIN SECTION -->
                        <div style="width:100%; margin-top:20px; margin-bottom:30px; overflow:hidden;">

                            <!-- LEFT -->
                            <div style="width:48%; float:left;">
                                <h3>Appointment Info</h3>

                                <p><strong>Patient:</strong> <t t-esc="doc.patient_id.name"/></p>
                                <p><strong>Doctor:</strong> <t t-esc="doc.doctor_id.name"/></p>
                                <p><strong>Specialization:</strong> <t t-esc="doc.specialization_id.name"/></p>
                                <p><strong>Company:</strong> <t t-esc="doc.company_id.name"/></p>

                                <p><strong>Fees:</strong> 
                                    <t t-esc="doc.fees" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                </p>
                            </div>
                            <!-- RIGHT -->
                            <div style="width:48%; float:right;">
                                <h3>Schedule</h3>

                                <p><strong>Start:</strong> 
                                    <t t-esc="context_timestamp(doc.start_date).strftime('%b %d, %I:%M %p') if doc.start_date else ''"/>
                                </p>

                                <p><strong>End:</strong> 
                                    <t t-esc="context_timestamp(doc.end_date).strftime('%b %d, %I:%M %p') if doc.end_date else ''"/>
                                </p>
                            </div>

                        </div>

                        <hr style="width:100%; clear:both; border:1px solid #444;"/>

                        <div>
                            <!-- MEDICAL INFO -->
                            <t t-if="doc.symptoms or doc.notes">

                                <h2 style="margin-top:20px;">Medical Information</h2>

                                <t t-if="doc.symptoms">
                                    <p style="margin-top:10px;">
                                        <strong>Symptoms:</strong><br/>
                                        <t t-esc="doc.symptoms"/>
                                    </p>
                                </t>

                                <t t-if="doc.notes">
                                    <p style="margin-top:10px;">
                                        <strong>Doctor Notes:</strong><br/>
                                        <t t-esc="doc.notes"/>
                                    </p>
                                </t>

                            </t>
                        </div>
                        <hr/>
                        <!-- CANCELLATION DETAILS -->
                        <t t-if="doc.state == 'cancel' and doc.cancel_reason">

                            <h2 style="margin-top:20px;">Cancellation Details</h2>

                            <p style="margin-top:10px;">
                                <strong>Reason:</strong><br/>
                                <t t-esc="doc.cancel_reason"/>
                            </p>

                        </t>
                 

                        
                    </div>

                </t>

            </t>
        </t>
    </template>

</odoo>