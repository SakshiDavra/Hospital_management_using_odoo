<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_pos_config_inherit_card_ui" model="ir.ui.view">
        <field name="name">pos.config.inherit.card.ui</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">

                <group string="Product Card UI">

                    <field name="enable_card_resize"/>

                    <field name="product_card_width"
                        invisible="not enable_card_resize"/>

                    <field name="product_card_height"
                        invisible="not enable_card_resize"/>

                    <field name="product_font_size"
                        invisible="not enable_card_resize"/>

                </group>

            </xpath>

        </field>
    </record>

</odoo>