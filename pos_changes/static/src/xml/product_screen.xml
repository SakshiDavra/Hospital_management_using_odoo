<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<t t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
    <xpath expr="//div[contains(@class,'product-list')]" position="attributes">
        <attribute name="t-att-style">
            env.services.pos.config?.enable_card_resize ? 
            `grid-template-columns: repeat(auto-fill, minmax(${env.services.pos.config.product_card_width}px, 1fr)) !important;` 
            : undefined
        </attribute>
    </xpath>
</t>

</templates>